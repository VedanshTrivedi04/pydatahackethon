# =============================================================================
# ShipFaster — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# =============================================================================

# --- Application ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
APP_NAME=ShipFaster
APP_VERSION=1.0.0

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shipfaster
DB_USER=shipfaster
DB_PASSWORD=shipfaster_dev_password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=shipfaster-artifacts
MINIO_SECURE=false

# --- LLM Providers ---
LLM_GOOGLE_API_KEY=your_google_gemini_api_key_here
LLM_ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_DEFAULT_MODEL=gemini-1.5-pro
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=120
LLM_MAX_TOKENS=8192

# --- GitHub App ---
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# --- viaSocket ---
VIASOCKET_MAX_RETRIES=3
VIASOCKET_TIMEOUT_SECONDS=30
VIASOCKET_RETRY_BACKOFF_BASE=2.0

# --- Security ---
SECURITY_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHARACTER_STRING_IN_PRODUCTION
SECURITY_API_KEY_LENGTH=64

# --- Sandbox ---
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_USE_DOCKER=false
